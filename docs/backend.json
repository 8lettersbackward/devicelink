{
  "entities": {
    "Buddy": {
      "title": "Emergency Buddy",
      "description": "A human contact for emergency orchestration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "groups": { "type": "array", "items": { "type": "string" } },
        "registeredAt": { "type": "number" }
      },
      "required": ["name", "phoneNumber"]
    },
    "SecurityGroup": {
      "title": "Security Protocol Group",
      "description": "A reusable group for contact orchestration.",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Node": {
      "title": "ESP32 Safety Node",
      "description": "A registered hardware safety device.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nodeName": { "type": "string" },
        "hardwareId": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "error"] },
        "temperature": { "type": "number" },
        "targetGroups": { "type": "array", "items": { "type": "string" } },
        "registeredAt": { "type": "number" }
      },
      "required": ["nodeName", "hardwareId", "status"]
    },
    "SOSStatus": {
      "title": "Master SOS Status",
      "description": "Global SOS trigger data for hardware synchronization.",
      "type": "object",
      "properties": {
        "sosTrigger": { "type": "boolean" },
        "sender": { "type": "string" },
        "nodename": { "type": "string" },
        "timestamp": { "type": "number" },
        "triggeredByNode": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "users/{userId}/buddies/{buddyId}": {
      "schema": "Buddy",
      "description": "Emergency contacts registered to a user."
    },
    "users/{userId}/buddyGroups/{groupId}": {
      "schema": "SecurityGroup",
      "description": "Reusable security protocol groups."
    },
    "users/{userId}/nodes/{nodeId}": {
      "schema": "Node",
      "description": "ESP32 nodes registered to a user."
    },
    "sosSystem": {
      "schema": "SOSStatus",
      "description": "Global SOS trigger status for hardware integration."
    }
  }
}