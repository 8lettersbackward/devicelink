
{
  "entities": {
    "Device": {
      "title": "Safety Device / Buddy",
      "description": "A registered emergency or safety hardware device or a human buddy.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "error"] },
        "ownerId": { "type": "string" },
        "type": { "type": "string", "description": "The specific type or relationship of the asset." },
        "category": { "type": "string", "enum": ["buddy", "node"] },
        "phoneNumber": { "type": "string", "description": "Contact number for human buddies." },
        "role": { "type": "string", "description": "The safety role of the buddy, e.g., Primary Emergency Contact." },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"], "description": "The alert priority for this contact." },
        "groups": { "type": "array", "items": { "type": "string" }, "description": "The safety groups this buddy belongs to." },
        "alertGroups": { "type": "array", "items": { "type": "string" }, "description": "The buddy groups alerted by this node." },
        "specialData": { "type": "string", "description": "Additional custom data or specific safety info." },
        "registeredAt": { "type": "number" },
        "lastActiveAt": { "type": "number" }
      },
      "required": ["name", "ownerId", "status", "category"]
    },
    "Notification": {
      "title": "Safety Alert",
      "description": "Emergency or safety system notification.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "message", "read"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Personal safety identification and emergency contact details.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      }
    },
    "ESPQueueEntry": {
      "title": "ESP Sync Entry",
      "description": "Data mirrored for hardware synchronization (ESP32/ESP8266).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "priority": { "type": "string" },
        "uid": { "type": "string" },
        "buddyId": { "type": "string" },
        "groups": { "type": "string", "description": "Comma-separated list of groups." },
        "processed": { "type": "boolean" },
        "timestamp": { "type": "number" }
      }
    },
    "SOSStatus": {
      "title": "SOS Status",
      "description": "Master SOS trigger data.",
      "type": "object",
      "properties": {
        "sosTrigger": { "type": "boolean" },
        "sender": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "users/{userId}/profile": {
      "schema": "UserProfile",
      "description": "Emergency responder contact info in Realtime Database."
    },
    "users/{userId}/devices/{deviceId}": {
      "schema": "Device",
      "description": "Safety devices or buddies registered to a user in Realtime Database."
    },
    "users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Personal safety alert history in Realtime Database."
    },
    "esp_queue/{userId}/{buddyId}": {
      "schema": "ESPQueueEntry",
      "description": "Queue for hardware device synchronization in Realtime Database."
    },
    "sos_system/{userId}": {
      "schema": "SOSStatus",
      "description": "Master SOS trigger status in Realtime Database."
    }
  }
}
